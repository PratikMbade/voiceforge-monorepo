# ╔══════════════════════════════════════════════════════════════════════════╗
# ║              VoiceForge — Environment Variables Reference               ║
# ║  Copy this file to .env  →  cp .env.example .env                       ║
# ║  Variables marked [REQUIRED] must be set before the app will start.    ║
# ║  Variables marked [DEFAULT OK] work fine as-is for local development.  ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── App Identity ─────────────────────────────────────────────────────────────

# [DEFAULT OK] Display name shown in API docs at /api/docs
PROJECT_NAME=VoiceForge API

# [DEFAULT OK]
VERSION=1.0.0

# [REQUIRED in prod] development | staging | production
ENV=development

# [DEFAULT OK for dev] Set false in production
DEBUG=true

# [REQUIRED in prod] Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-insecure-key-change-in-production


# ── Server ───────────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8000

# JSON array of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]


# ── Database ─────────────────────────────────────────────────────────────────

# DEV — SQLite, no setup needed
DATABASE_URL=sqlite+aiosqlite:///./voiceforge.db

# PROD / Docker Compose — uncomment and use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://voiceforge:voiceforge@postgres:5432/voiceforge


# ── Redis & Celery ───────────────────────────────────────────────────────────
# Redis is NOT optional. Celery needs it for async TTS jobs.

# Local Redis (dev)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Docker Compose — uncomment:
# REDIS_URL=redis://redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1


# ── File Storage (auto-created on startup) ───────────────────────────────────

MODELS_DIR=./models
VOICES_DIR=./storage/voices
AUDIO_OUTPUT_DIR=./storage/audio
UPLOADS_DIR=./storage/uploads


# ── TTS Model ────────────────────────────────────────────────────────────────
# Model is downloaded automatically on first run (~200MB-1GB).
#
# Fast/CPU (good for dev):
#   tts_models/en/ljspeech/tacotron2-DDC
#
# Best quality + voice cloning (needs GPU, closest to ElevenLabs):
#   tts_models/multilingual/multi-dataset/xtts_v2
#
# Full list: https://github.com/coqui-ai/TTS#models

TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
TTS_VOCODER=vocoder_models/en/ljspeech/multiband-melgan
MAX_TEXT_LENGTH=5000
AUDIO_SAMPLE_RATE=22050


# ── Voice Cloning ────────────────────────────────────────────────────────────

CLONING_MIN_AUDIO_SECONDS=6.0
CLONING_MAX_AUDIO_SECONDS=180.0


# ── MLflow (non-critical, app works if unreachable) ──────────────────────────

# Local
MLFLOW_TRACKING_URI=http://localhost:5000
# Docker Compose: MLFLOW_TRACKING_URI=http://mlflow:5000

MLFLOW_EXPERIMENT_NAME=voiceforge-tts


# ── Upload Limits ────────────────────────────────────────────────────────────

MAX_UPLOAD_SIZE_MB=50
